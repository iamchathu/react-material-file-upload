{
  "name": "react-material-file-upload",
  "version": "0.0.4",
  "description": "File upload component for React with Material UI components",
  "type": "module",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./lib/index.js",
      "default": "./lib/index.js"
    }
  },
  "files": [
    "lib"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iamchathu/react-material-file-upload.git"
  },
  "author": "Chathu Vishwajith <iam@chathu.me>",
  "license": "MIT",
  "scripts": {
    "clean": "rimraf lib/",
    "types:check": "tsc -p tsconfig.json --noEmit",
    "build": "tsup",
    "lint": "eslint 'src/**/*.{ts,tsx}' --quiet --fix ",
    "prepublishOnly": "pnpm clean && pnpm build",
    "semantic-release": "semantic-release",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "peerDependencies": {
    "@emotion/react": "^11.4.1",
    "@emotion/styled": "^11.3.0",
    "@mui/icons-material": "^7.0.0",
    "@mui/material": "^7.0.0",
    "@mui/system": "^7.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^13.2.1",
    "@commitlint/config-conventional": "^13.2.0",
    "@eslint/compat": "^2.0.3",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@storybook/addon-docs": "^10.2.19",
    "@storybook/addon-links": "^10.2.19",
    "@storybook/react-vite": "^10.2.19",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-storybook": "^10.2.13",
    "husky": "^7.0.2",
    "lint-staged": "^16.3.2",
    "prettier": "^3.8.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rimraf": "^6.1.3",
    "semantic-release": "^25.0.3",
    "storybook": "^10.2.19",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "react-dropzone": "^15.0.0"
  },
  "keywords": [
    "react",
    "react component",
    "file upload",
    "material ui",
    "upload"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "volta": {
    "node": "24.14.0"
  }
}
